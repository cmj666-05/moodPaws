PORT=3001
DB_PATH=./data/moodpaws.db
DATA_MODE=sqlite
CORS_ORIGIN=*
MDNS_ENABLED=true
MDNS_SERVICE_NAME=moodpaws-server
SERVICE_ID=

# Python 图传服务配置。三种填法任选一种，优先级从上到下：
# 1. 完整地址：VIDEO_STREAM_URL=http://camera-box.local:5000/video_feed
# 2. 源站地址：VIDEO_STREAM_ORIGIN=http://camera-box.local:5000
# 3. 主机名/局域网名：VIDEO_STREAM_HOST=camera-box.local
#
# 如果视频服务和主后端不在同一台机器，推荐优先使用 .local 主机名，
# 这样局域网 IP 变化时 App 仍能通过主机名连接到 Python 图传服务。
VIDEO_STREAM_ENABLED=true
VIDEO_STREAM_URL=
VIDEO_STREAM_ORIGIN=
VIDEO_STREAM_HOST=
VIDEO_STREAM_PORT=5000
VIDEO_STREAM_PATH=/video_feed

ENABLE_MQTT=true
MQTT_BROKER_URL=wss://iot-06z00b1eo2alugk.mqtt.iothub.aliyuncs.com:443/mqtt
MQTT_TOPICS=/k1wxaEnEO8L/petInfo/user/get
MQTT_CLIENT_ID=k1wxaEnEO8L.petInfo|securemode=2,signmethod=hmacsha256|
MQTT_USERNAME=petInfo&k1wxaEnEO8L
MQTT_PASSWORD=replace-with-real-password
MQTT_RECONNECT_PERIOD=3000
MQTT_CONNECT_TIMEOUT=10000
MQTT_PROTOCOL_VERSION=4
