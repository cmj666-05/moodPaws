# 阿里云 IoT 基础信息
VITE_ALIYUN_REGION_ID=cn-shanghai
VITE_ALIYUN_PRODUCT_KEY=k1wxaEnEO8L
VITE_ALIYUN_DEVICES=Collar,DogHouse

# App 直连阿里云 MQTT
VITE_ALIYUN_MQTT_ENABLED=true
# native: 仅 Android/Capacitor 真机启动；always: Web 调试也启动；web: 仅浏览器启动
VITE_ALIYUN_MQTT_RUNTIME=native
VITE_ALIYUN_MQTT_BROKER_URL=wss://iot-xxxx.mqtt.iothub.aliyuncs.com:443/mqtt
VITE_ALIYUN_MQTT_TOPICS=/yourProductKey/petInfo/user/get
VITE_ALIYUN_MQTT_CLIENT_ID=yourProductKey.petInfo|securemode=2,signmethod=hmacsha256|
VITE_ALIYUN_MQTT_USERNAME=petInfo&yourProductKey
VITE_ALIYUN_MQTT_PASSWORD=your-mqtt-password
VITE_ALIYUN_MQTT_RECONNECT_PERIOD=3000
VITE_ALIYUN_MQTT_CONNECT_TIMEOUT=10000
VITE_ALIYUN_MQTT_PROTOCOL_VERSION=4

# 可选：如果后续还需要 App 主动回补阿里云历史属性，再填写 OpenAPI AccessKey。
VITE_ALIYUN_IOT_ENDPOINT=
VITE_ALIYUN_IOT_INSTANCE_ID=
VITE_ALIYUN_ACCESS_KEY_ID=
VITE_ALIYUN_ACCESS_KEY_SECRET=
VITE_ALIYUN_PROPERTY_QUERY_MODE=standard
VITE_ALIYUN_HISTORY_LOOKBACK_MINUTES=1440
VITE_ALIYUN_HISTORY_MAX_PAGES=3
VITE_ALIYUN_HISTORY_PAGE_SIZE=50
VITE_ALIYUN_ONLINE_WINDOW_MINUTES=5

# App 拉取/刷新频率
VITE_API_POLL_INTERVAL=5000
VITE_API_DETAILS_POLL_INTERVAL=30000

# 视频流仍独立配置
VITE_VIDEO_STREAM_URL=
VITE_VIDEO_MDNS_SERVICE_NAME=flocakweb
VITE_VIDEO_MDNS_SERVICE_TYPE=_http._tcp.
VITE_VIDEO_DISCOVERY_TIMEOUT=2500
VITE_VIDEO_STREAM_PORT=5000
VITE_VIDEO_STREAM_PATH=/video_feed
