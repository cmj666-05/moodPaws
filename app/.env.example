VITE_API_BASE_URL=http://YOUR_SERVER_IP:3001/api
VITE_API_POLL_INTERVAL=5000
VITE_MDNS_SERVICE_NAME=moodpaws-server
VITE_API_DISCOVERY_TIMEOUT=3500

# 已知完整视频地址时可直接填写，例如：
# VITE_VIDEO_STREAM_URL=http://camera-box.local:5000/video_feed
VITE_VIDEO_STREAM_URL=

# 如果不直接填写完整地址，App 会优先读取主后端 /api/health 返回的视频配置。
# 只有在主后端没有提供视频配置时，才会尝试独立发现局域网视频服务。
VITE_VIDEO_MDNS_SERVICE_NAME=flocakweb
VITE_VIDEO_MDNS_SERVICE_TYPE=_http._tcp.
VITE_VIDEO_DISCOVERY_TIMEOUT=2500
VITE_VIDEO_STREAM_PORT=5000
VITE_VIDEO_STREAM_PATH=/video_feed
